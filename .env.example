# Environment Variables Template
# Copy to .env and fill in actual values. Production .env is chmod 600.
# For local dev, use .env.local with only the vars you need.

# ── Gemini AI ──────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Server ─────────────────────────────────────────────────
PORT=3000
COOKIE_SECRET=generate_with_openssl_rand_hex_32
DATA_ENCRYPTION_KEY=generate_with_openssl_rand_hex_32

# ── SMTP (email notifications) ─────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password

# ── HotelInCloud Integration ──────────────────────────────
HOTELINCLOUD_EMAIL=your_hotelincloud_email
HOTELINCLOUD_PASSWORD=your_hotelincloud_password
HOTELINCLOUD_TOTP_SECRET=your_totp_secret

# ── WhatsApp Cloud API ─────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_APP_SECRET=your_app_secret_for_signature_verification
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token

# ── Phone / SIP ────────────────────────────────────────────
PHONE_WEBHOOK_SECRET=generate_with_openssl_rand_hex_32

# ── Google APIs ────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_maps_api_key
GOOGLE_PLACES_API_KEY=your_places_api_key

# ── Management ─────────────────────────────────────────────
MANAGEMENT_EMAIL=admin@example.com
