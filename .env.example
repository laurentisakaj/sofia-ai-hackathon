# Environment Variables Template
# Copy to .env and fill in actual values. Production .env is chmod 600.
# For local dev, use .env.local with only the vars you need.

# ── Gemini AI ──────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Server ─────────────────────────────────────────────────
PORT=3000
COOKIE_SECRET=generate_with_openssl_rand_hex_32
DATA_ENCRYPTION_KEY=generate_with_openssl_rand_hex_32
ENCRYPTION_SALT=generate_with_openssl_rand_hex_16

# ── SMTP (email notifications) ─────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-app-password

# ── HotelInCloud Integration ──────────────────────────────
HOTELINCLOUD_EMAIL=your_hotelincloud_email
HOTELINCLOUD_PASSWORD=your_hotelincloud_password
HOTELINCLOUD_TOTP_SECRET=your_totp_secret

# ── WhatsApp Cloud API ─────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id
WHATSAPP_APP_SECRET=your_app_secret_for_signature_verification
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_PHONE_NUMBER=+39xxxxxxxxxx

# ── WhatsApp Flows ───────────────────────────────────────────
FLOW_ID_BOOKING=your_booking_flow_id
FLOW_ID_CHECKIN=your_checkin_flow_id
FLOW_ID_TOURS=your_tours_flow_id
FLOW_ID_FEEDBACK=your_feedback_flow_id
FLOWS_PRIVATE_KEY=your_rsa_private_key_pem_format

# ── Phone / SIP (Messagenet) ─────────────────────────────────
PHONE_WEBHOOK_SECRET=generate_with_openssl_rand_hex_32
PHONE_HASH_SECRET=generate_with_openssl_rand_hex_32
MESSAGENET_USERID=your_messagenet_user_id
MESSAGENET_PASSWORD=your_messagenet_password
MESSAGENET_SENDER=your_messagenet_sender_number
SIP_USERNAME=your_sip_username
SIP_PASSWORD=your_sip_password
SIP_DOMAIN=sip.messagenet.it
SIP_PROXY_PORT=5070

# ── Google APIs ────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_maps_api_key
GOOGLE_PLACES_API_KEY=your_places_api_key
GOOGLE_SERVER_API_KEY=your_server_api_key

# ── Google Cloud (Firestore for cross-server sync) ─────────
FIRESTORE_PROJECT_ID=your_gcp_project_id
# On non-GCP servers, also set:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ── Web Push Notifications ─────────────────────────────────
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:your-email@example.com

# ── Quotation API ──────────────────────────────────────────
QUOTATION_API_KEY=your_quotation_api_key

# ── Admin ──────────────────────────────────────────────────
ADMIN_PASSWORD=your_admin_password
VITE_ADMIN_PIN=your_admin_pin
MANAGEMENT_EMAIL=admin@example.com
